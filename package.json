{
  "name": "effector-refetch",
  "version": "0.4.0",
  "description": "Friendly query layer for effector, built on real effects",
  "keywords": [
    "effector",
    "query",
    "data-fetching",
    "cache",
    "mutation",
    "pagination",
    "fetch",
    "react",
    "vue",
    "ssr"
  ],
  "homepage": "https://olovyannikov.github.io/effector-query/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Olovyannikov/effector-query.git"
  },
  "bugs": "https://github.com/Olovyannikov/effector-query/issues",
  "author": "Ilya Olovyannikov",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "import": "./dist/solid.mjs",
      "require": "./dist/solid.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.cjs"
    },
    "./devtools/vue": {
      "types": "./dist/devtools-vue.d.ts",
      "import": "./dist/devtools-vue.mjs",
      "require": "./dist/devtools-vue.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "changeset": "changeset",
    "release": "pnpm run build && pnpm publish --no-git-checks",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "effector": ">=23",
    "effector-react": ">=23",
    "effector-vue": ">=23",
    "effector-solid": ">=0.23",
    "react": ">=18",
    "vue": ">=3",
    "solid-js": ">=1.7"
  },
  "peerDependenciesMeta": {
    "effector-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "effector-vue": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "effector-solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.11",
    "axios": "^1.17.0",
    "effector": "^23.2.2",
    "effector-react": "^23.3.0",
    "effector-solid": "^0.23.0",
    "effector-vue": "^23.1.1",
    "eslint": "^10.4.1",
    "eslint-plugin-effector": "^0.18.0",
    "happy-dom": "^20.10.2",
    "ofetch": "^1.5.1",
    "patronum": "^2.3.0",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "solid-js": "^1.9.13",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^2.0.5",
    "vue": "^3.5.35"
  },
  "packageManager": "pnpm@11.5.1",
  "license": "MIT"
}
